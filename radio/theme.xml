<theme>
	<formatVersion>4</formatVersion>
	<include>./../theme.xml</include>
	<view name="system">
                <image name="systemsnap" extra="true">
                   <origin>0.5 0.5</origin>
                   <pos>0.5 0.5</pos>
                   <maxSize>0.8 0.7</maxSize>
                   <path>./_inc/systemsnap.png</path>
                </image>
 		<text name="systemDesc" extra="true">
         <text>Listen to various online radio streams.</text>
			<text lang="es">Escuche varias transmisiones de radio en línea.</text>
			<text lang="de">Hören Sie verschiedene Online-Radiostreams.</text>
			<text lang="fr">Écoutez divers flux de radio en ligne.</text>
			<text lang="it">Ascolta vari flussi radio online.</text>       
      <zIndex>100</zIndex>
		 <alignment>left</alignment>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
      </text>
	</view>
</theme>
