<theme>
	<formatVersion>4</formatVersion>
	<include>./../theme.xml</include>
	<view name="system">
                <image name="systemsnap" extra="true">
                   <origin>0.5 0.5</origin>
                   <pos>0.5 0.5</pos>
                   <maxSize>0.8 0.7</maxSize>
                   <path>./_inc/systemsnap-it.png</path>
                </image>
 		<text name="systemDesc" extra="true">
         <text>Gallery of screenshots taken during the game.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="es">Galería de capturas de pantalla tomadas durante el juego.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="de">Galerie mit Screenshots, die während des Spiels aufgenommen wurden.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="fr">Galerie de captures d'e'cran prises pendant le jeu.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="it">Galleria di screenshot acquisiti durante il gioco.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>       
      <zIndex>100</zIndex>
		 <alignment>left</alignment>      <multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
	</view>
</theme>




