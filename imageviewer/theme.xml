<theme>
	<formatVersion>4</formatVersion>
	<include>./../theme.xml</include>
	<view name="system">
                <image name="systemsnap" extra="true">
                   <origin>0.5 0.5</origin>
                   <pos>0.5 0.5</pos>
                   <maxSize>0.8 0.7</maxSize>
                   <path>./_inc/systemsnap-it.png</path>
                </image>
 		<text name="systemDesc" extra="true">
         <text>Gallery of screenshots taken during the game.</text>
			<text lang="es">Galería de capturas de pantalla tomadas durante el juego.</text>
			<text lang="de">Galerie mit Screenshots, die während des Spiels aufgenommen wurden.</text>
			<text lang="fr">Galerie de captures d'écran prises pendant le jeu.</text>
			<text lang="it">Galleria di screenshot acquisiti durante il gioco.</text>       
      <zIndex>100</zIndex>
		 <alignment>left</alignment>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
      </text>
	</view>
</theme>
