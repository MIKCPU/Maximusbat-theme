<theme>
	<formatVersion>4</formatVersion>
	<include>./../theme.xml</include>
	<view name="system">
                <image name="systemsnap" extra="true">
                   <origin>0.5 0.5</origin>
                   <pos>0.5 0.5</pos>
                   <maxSize>0.8 0.7</maxSize>
                   <path>./_inc/systemsnap.png</path>
                </image>
 		<text name="systemDesc" extra="true">
         <text>A collection of fighting games. The collection is taken from your available games.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="es">Una colección de juegos de lucha. La colección se toma de tus juegos disponibles.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="de">Eine Sammlung von Kampfspielen. Die Sammlung wird aus Ihren verfügbaren Spielen übernommen.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="fr">Une collection de jeux de combat. La collection est extraite de vos jeux disponibles.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="it">Una raccolta di giochi di combattimento. La raccolta e' presa dai tuoi giochi disponibili.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>       
      <zIndex>100</zIndex>
		 <alignment>left</alignment>      <multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
	</view>
</theme>




