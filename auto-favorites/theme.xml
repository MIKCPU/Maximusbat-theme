<theme>
	<formatVersion>4</formatVersion>
	<include>./../theme.xml</include>
	<view name="system">
                <image name="systemsnap" extra="true">
                   <origin>0.5 0.5</origin>
                   <pos>0.5 0.5</pos>
                   <maxSize>0.8 0.7</maxSize>
                   <path>./_inc/systemsnap-it.png</path>
                </image>
 		<text name="systemDesc" extra="true">
         <text>Here's a collection of all games, from all systems, that have been added to favorites.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="es">Aquí tienes una recopilación de todos los juegos, de todos los sistemas, que se han añadido a favoritos.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="de">Hier ist eine Sammlung aller Spiele von allen Systemen, die zu den Favoriten hinzugefügt wurden.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="fr">Voici une collection de tous les jeux, tous syste'mes confondus, qui ont e'te' ajoute's aux favoris.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="it">Ecco una raccolta di tutti i giochi, di tutti i sistemi, che sono stati aggiunti ai preferiti.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>       
      <zIndex>100</zIndex>
		 <alignment>left</alignment>      <multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
	</view>
</theme>




