<singleLineScroll ifSubset="view:Carousel">true</singleLineScroll>
      </text>
			<text lang="es">Una colección de increíbles juegos arcade. La colección se toma de tus juegos disponibles.<multiLine ifSubset="view:Carousel">false</multiLine>
