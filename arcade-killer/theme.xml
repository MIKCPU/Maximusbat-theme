			<text lang="de">Eine Sammlung von Killer-Arcade-Spielen. Die Sammlung wird aus Ihren verfügbaren Spielen übernommen.<multiLine ifSubset="view:Carousel">false</multiLine>
<autoScrollDelay ifSubset="view:Carousel">3000</autoScrollDelay>
